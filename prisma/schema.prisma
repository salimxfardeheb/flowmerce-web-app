generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(VENDOR)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vendor        Vendor?
  sessions      Session[]
  accounts      Account[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vendor {
  id                   String         @id @default(cuid())
  userId               String         @unique
  companyName          String
  siret                String?
  phone                String
  address              String
  website              String?
  status               VendorStatus   @default(PENDING)
  rejectionReason      String?
  requestedDocuments   DocumentType[] @default([])
  vendorCategories  String[]  @default([])

  documents    Document[]
  returnPolicy ReturnPolicy?
  apiKeys      ApiKey[]
  claims       Claim[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Document {
  id              String         @id @default(cuid())
  vendorId        String
  name            String
  url             String
  type            DocumentType
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime       @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model ReturnPolicy {
  id                     String         @id @default(cuid())
  vendorId               String         @unique
  allowRefusalOnDelivery Boolean        @default(false)
  maxClaimDays           Int            @default(14)
  acceptedTypes          ClaimType[]
  validationMode         ValidationMode @default(MANUAL)
  fraudScoreThreshold    Int            @default(70)
  fraudReturnThreshold   Int            @default(4)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id         String    @id @default(cuid())
  vendorId   String
  name       String
  // SHA-256 hex (64 chars) du raw key. Le raw n'est jamais persisté.
  key        String    @unique
  // Préfixe public (12 premiers chars du raw) — affiché au vendeur
  // pour identifier la clé sans pouvoir la réutiliser.
  keyPrefix  String?
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  vendor         Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  returnSessions ReturnSession[]

  @@index([vendorId])
  @@index([key])
}

model ReturnSession {
  id            String    @id @default(cuid())
  token         String    @unique
  vendorId      String
  orderId       String
  customerEmail String
  productName   String
  customerName  String
  customerPhone String    @default("")
  orderDate     String    @default("")
  shopName      String    @default("")
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  vendor        ApiKey    @relation(fields: [vendorId], references: [id])
}

model Claim {
  id            String      @id @default(cuid())
  vendorId      String
  orderId       String

  customerName  String
  customerEmail String

  // ── Nouveaux champs page retour ──────────────────────────────
  productName   String?     // nom du produit commandé
  orderDate     DateTime?   // date de la commande
  source        ClaimSource @default(API) // origine : api ou page hébergée
  fraudScore    Float?      // score de risque 0-100 calculé à la soumission
  ipAddress     String?     // IP du client (pour anti-fraude)

  type          ClaimType
  description   String

  status        ClaimStatus @default(PENDING)

  aiScore       Float?
  aiDecision    String?
  prediction    Json?
  processedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, orderId])
  @@index([vendorId, createdAt(sort: Desc)])
  @@index([vendorId])
  @@index([status])
  @@index([orderId])
}

model PredictionLog {
  id       String   @id @default(cuid())
  claimId  String?
  vendorId String
  input    Json
  output   Json
  createdAt DateTime @default(now())

  @@index([vendorId])
  @@index([claimId])
}

// ── Rate limiting (anti-spam page retour) ────────────────────
model ReturnRateLimit {
  id        String   @id @default(cuid())
  key       String   @unique  // "ip:orderId" ou "orderId"
  count     Int      @default(1)
  resetAt   DateTime

  @@index([key])
  @@index([resetAt])
}

// ── Tracking cross-boutique des clients à risque ──────────────
model CustomerFraudRecord {
  id            String    @id @default(cuid())
  // Matching OR : correspond si email OU phone correspond
  customerEmail String?
  customerPhone String?
  // Compteurs cross-boutique
  totalClaims   Int       @default(0)   // nb de réclamations toutes boutiques
  totalRefusals Int       @default(0)   // nb de refus à la livraison signalés
  // Dernière activité
  lastClaimAt   DateTime?
  lastRefusalAt DateTime?
  // Audit
  matchedBy     String?                 // "email" | "phone" | "both"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([customerEmail])
  @@index([customerPhone])
}

enum Role {
  ADMIN
  VENDOR
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  DOCUMENTS_REQUESTED
}

enum DocumentType {
  ID_CARD
  BUSINESS_REGISTRATION
  ADDRESS_PROOF
  TAX_CERTIFICATE
  BANK_DETAILS
  OTHER
}

enum DocumentStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ValidationMode {
  MANUAL
  AI_AUTO
}

enum ClaimType {
  EXCHANGE
  REFUND
  REPAIR
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
}

enum ClaimSource {
  API          // soumis via API directe (ancien flux)
  HOSTED_PAGE  // soumis via la page hébergée Flowmerce
}
