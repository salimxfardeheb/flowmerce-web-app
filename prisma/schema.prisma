generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(VENDOR)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  accounts  Account[]
  sessions  Session[]
  vendor    Vendor?

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vendor {
  id                 String         @id @default(cuid())
  userId             String         @unique
  companyName        String
  phone              String
  address            String
  website            String?
  status             VendorStatus   @default(PENDING)
  rejectionReason    String?
  requestedDocuments DocumentType[] @default([])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  vendorCategories   String[]       @default([])
  apiKeys            ApiKey[]
  claims             Claim[]
  documents          Document[]
  returnPolicy       ReturnPolicy?
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Document {
  id                 String         @id @default(cuid())
  vendorId           String
  name               String
  url                String
  cloudinaryPublicId String?
  type               DocumentType
  createdAt          DateTime       @default(now())
  rejectionReason    String?
  status             DocumentStatus @default(PENDING)
  vendor             Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model ReturnPolicy {
  id                      String         @id @default(cuid())
  vendorId                String         @unique
  allowRefusalOnDelivery  Boolean        @default(false)
  maxClaimDays            Int            @default(14)
  acceptedTypes           ClaimType[]
  validationMode          ValidationMode @default(MANUAL)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  fraudScoreThreshold     Int            @default(70)
  fraudReturnThreshold    Int            @default(4)
  acceptedReturnReasons   String[]       @default([])
  exchangeOnlyCategories  String[]       @default([])
  nonRefundableCategories String[]       @default([])
  partialRefundEnabled    Boolean        @default(false)
  partialRefundRules      Json?
  processingDays          Int            @default(5)
  vendor                  Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id             String          @id @default(cuid())
  vendorId       String
  name           String
  key            String          @unique
  isActive       Boolean         @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime        @default(now())
  keyPrefix      String?
  vendor         Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  returnSessions ReturnSession[]

  @@index([vendorId])
  @@index([key])
}

model ReturnSession {
  id            String    @id @default(cuid())
  token         String    @unique
  vendorId      String
  orderId       String
  customerEmail String
  productName   String
  customerName  String
  customerPhone String    @default("")
  orderDate       String    @default("")
  shopName        String    @default("")
  productPrice    Float?
  productQuantity Int?
  orderTotal      Float?
  expiresAt       DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
  vendor        ApiKey    @relation(fields: [vendorId], references: [id])
}

model Claim {
  id            String      @id @default(cuid())
  vendorId      String
  apiKeyId      String? 
  orderId       String
  customerName  String
  customerEmail String
  customerPhone String?
  type          ClaimType
  description   String
  status        ClaimStatus @default(PENDING)
  aiScore       Float?
  aiDecision    String?
  prediction    Json?
  processedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  productName   String?
  orderDate     DateTime?
  source        ClaimSource @default(API)
  fraudScore    Float?
  ipAddress     String?
  mlFailed      Boolean     @default(false)
  mlAttempts    Int         @default(0)
  mlInput       Json?
  vendor        Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, orderId])
  @@index([vendorId, createdAt(sort: Desc)])
  @@index([vendorId, status])
  @@index([vendorId])
  @@index([status])
  @@index([orderId])
  @@index([mlFailed])
}

model PredictionLog {
  id        String   @id @default(cuid())
  claimId   String?
  vendorId  String
  input     Json
  output    Json
  createdAt DateTime @default(now())

  @@index([vendorId])
  @@index([claimId])
}

model ReturnRateLimit {
  id      String   @id @default(cuid())
  key     String   @unique
  count   Int      @default(1)
  resetAt DateTime

  @@index([key])
  @@index([resetAt])
}

model CustomerFraudRecord {
  id              String    @id @default(cuid())
  customerEmail   String?
  customerPhone   String?
  totalClaims     Int       @default(0)
  totalRefusals   Int       @default(0)
  distinctVendors Int       @default(0)
  lastClaimAt     DateTime?
  lastRefusalAt   DateTime?
  matchedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([customerEmail])
  @@index([customerPhone])
}

model RefusalReport {
  id            String   @id @default(cuid())
  vendorId      String
  customerEmail String?
  customerPhone String?
  orderId       String
  claimId       String?
  reason        String?
  createdAt     DateTime @default(now())

  @@unique([vendorId, orderId])
  @@index([vendorId])
  @@index([customerEmail])
  @@index([customerPhone])
  @@index([createdAt])
}

enum Role {
  ADMIN
  VENDOR
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  DOCUMENTS_REQUESTED
}

enum DocumentType {
  ID_CARD
  BUSINESS_REGISTRATION
  ADDRESS_PROOF
  TAX_CERTIFICATE
  BANK_DETAILS
  OTHER
}

enum DocumentStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ValidationMode {
  MANUAL
  AI_AUTO
}

enum ClaimType {
  EXCHANGE
  REFUND
  REPAIR
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
}

enum ClaimSource {
  API
  HOSTED_PAGE
}
