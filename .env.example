# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── NextAuth ──────────────────────────────────────────────────────────────
# Min 32 characters. Generate: openssl rand -base64 48
NEXTAUTH_SECRET=
AUTH_SECRET=
# Optional. Set in non-Vercel hosts. Vercel autodetects.
NEXTAUTH_URL=

# ─── Vendor portal HMAC (lib/vendor-portal-token.ts) ───────────────────────
# Min 32 characters.
VENDOR_PORTAL_SECRET=

# ─── Cron jobs (app/api/cron/*) ────────────────────────────────────────────
# Min 32 characters. Generate: openssl rand -hex 32
# Vercel Cron envoie automatiquement "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

# ─── ML API (lib/services/ml.ts) ───────────────────────────────────────────
ML_API_URL=https://your-ml-api.example.com
# Min 16 characters. Shared with the ML backend.
ML_INTERNAL_SECRET=

# ─── Gmail (lib/services/notification.ts) ──────────────────────────────────
GMAIL_USER=your-account@gmail.com
# 16-character app password.
GMAIL_APP_PASSWORD=

# ─── Cloudinary (lib/cloudinary.ts) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Public — exposed to client bundle ─────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ─── Optional: generic SMTP fallback (lib/notifications/email.ts) ──────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Optional: Twilio SMS (lib/notifications/sms.ts) ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_DEFAULT_COUNTRY_CODE=213

# ─── Optional: logger level (debug | info | warn | error). Default: info ───
LOG_LEVEL=info
